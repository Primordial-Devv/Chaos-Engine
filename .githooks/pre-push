#!/bin/sh
while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/dev)
      branch="${remote_ref#refs/heads/}"
      echo "Push direct vers '$branch' refuse : passe par une pull request (voir docs/git-workflow.md)." >&2
      exit 1
      ;;
  esac
done
exit 0
